<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      metal:define-macro="master">
<head>

    <meta charset="UTF-8" />
    <title>${titol}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="http://www.w3schools.com/lib/w3.css" />


    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="style.css">

    <metal:extra-css define-slot="extra_css"></metal:extra-css>
</head>
<body>
    <header class="main-header">
        <div class="header-container">
            <a href="index.html" class="logo-wrapper">
                <img src="logotipohotel.png" alt="Lumina Logo" class="header-logo-img">
                <span class="logo-text">LUMINA</span>
            </a>
            
            <nav class="nav-desktop">
                <a href="index.html" class="active">Início</a>
                <a href="quartos.html">Quartos</a>
                <a href="instalacoes.html">Instalações</a>
                <a href="login.html" class="nav-login">Login</a>
            </nav>

            <button class="mobile-menu-btn">
                <i class="fa-solid fa-bars"></i>
            </button>
        </div>
    </header>

    <main metal:define-slot="main">
        Contingut per defecte
    </main>

        <footer class="main-footer">
        <div class="footer-container">
            <div class="footer-section">
                <div class="footer-logo-box">
                    <img src="logotipohotel.png" alt="Lumina Logo" class="footer-logo-img">
                    <h4 style="margin-top: 10px;">Lumina Grand Hotel</h4>
                </div>
                <p><i class="fa-solid fa-phone"></i> +351 210 000 000</p>
                <p><i class="fa-solid fa-envelope"></i> reservas@lumina.com</p>
            </div>
            
            <div class="footer-section">
                <h4>Links Úteis</h4>
                <a href="#">FAQ</a>
                <a href="#">Termos e Condições</a>
                <a href="#">Privacidade</a>
            </div>

            <div class="footer-section">
                <h4>Siga-nos</h4>
                <div class="social-links">
                    <a href="#"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="#"><i class="fa-brands fa-linkedin-in"></i></a>
                </div>
            </div>
        </div>
        
        <div class="footer-bottom">
            © 2026 Lumina Grand Hotel. Todos os direitos reservados.
        </div>
    </footer>

    <metal:extra-js define-slot="extra_js"></metal:extra-js>
</body>
</html>
