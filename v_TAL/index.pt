<html metal:use-macro="load: base.pt">
<head></head>
<body>
    <header metal:fill-slot="main-header">
        <h1>${titol}</h1>
    </header>

    <main metal:fill-slot="main">        
        <section class="hero-premium">
            <div class="hero-overlay-center">
                <span class="badge badge-gold">El Arte del Lujo</span>
                <h1 class="hero-logo-title">LUMINA GRAND HOTEL</h1>
                <p>Donde el refinamiento se encuentra con el horizonte en Cascais.</p>
            </div>
        </section>

        <section class="offers-section">
            <div class="header-container">
                <div class="section-intro" style="text-align: center; margin-bottom: 40px;">
                    <span class="badge badge-gold">Servicios Exclusivos</span>
                    <h2 class="section-title">Experiencias de Temporada</h2>
                    <p style="color: var(--gray-text);">Haz clic en las tarjetas para descubrir los detalles de cada programa.</p>
                </div>

                <div class="offers-grid horizontal-layout">
                    
                    <div class="offer-room-style clickable-card" onclick="this.classList.toggle('active')">
                        <div class="offer-img-box">
                            <img src="https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?auto=format&fit=crop&w=600&q=80" alt="Pack Romántico">
                        </div>
                        <div class="offer-details">
                            <span class="offer-category">Romance</span>
                            <h3>Pack Romántico</h3>
                            
                            <div class="offer-description">
                                <p class="short-desc">Espumoso y cena a la luz de las velas en la suite.</p>
                                
                                <div class="full-info-box">
                                    <p class="full-desc">Una noche diseñada para el amor. Incluye decoración personalizada con pétalos de rosa, una botella de espumoso premium a la llegada y un menú degustación de 3 platos servido de forma privada en la habitación.</p>
                                    <ul class="offer-specs">
                                        <li><i class="fa-regular fa-clock"></i> <strong>Horario:</strong> Bajo reserva (Cena a las 20:00)</li>
                                        <li><i class="fa-solid fa-location-dot"></i> <strong>Lugar:</strong> Suite Privada</li>
                                        <li><i class="fa-solid fa-euro-sign"></i> <strong>Coste:</strong> 80€ por pareja</li>
                                    </ul>
                                </div>
                            </div>

                            <div class="offer-footer">
                                <span class="price-tag">80€</span>
                                <span class="btn-text">Saber Más <i class="fa-solid fa-plus"></i></span>
                            </div>
                        </div>
                    </div>

                    <div class="offer-room-style clickable-card" onclick="this.classList.toggle('active')">
                        <div class="offer-img-box">
                            <img src="https://images.unsplash.com/photo-1516280440614-37939bbacd81?auto=format&fit=crop&w=600&q=80" alt="Karaoke">
                        </div>
                        <div class="offer-details">
                            <span class="offer-category">Ocio</span> 
                            <h3>Noche de Karaoke</h3>
                            
                            <div class="offer-description">
                                <p class="short-desc">Viernes animados en nuestro Lounge Bar.</p>
                                
                                <div class="full-info-box">
                                    <p class="full-desc">¡Libera tu voz en el escenario del Lumina! Una noche relajada con sistema de sonido de alta fidelidad, lista de canciones internacionales y cócteles de autor con descuento para participantes.</p>
                                    <ul class="offer-specs">
                                        <li><i class="fa-regular fa-clock"></i> <strong>Horario:</strong> Viernes, 21:30 - 01:00</li>
                                        <li><i class="fa-solid fa-location-dot"></i> <strong>Lugar:</strong> Blue Horizon Lounge</li>
                                        <li><i class="fa-solid fa-euro-sign"></i> <strong>Coste:</strong> Entrada gratuita</li>
                                    </ul>
                                </div>
                            </div>

                            <div class="offer-footer">
                                <span class="price-tag">Gratis</span>
                                <span class="btn-text">Saber Más <i class="fa-solid fa-plus"></i></span>
                            </div>
                        </div>
                    </div>

                    <div class="offer-room-style clickable-card" onclick="this.classList.toggle('active')">
                        <div class="offer-img-box">
                            <img src="https://images.unsplash.com/photo-1553284965-83fd3e82fa5a?auto=format&fit=crop&w=600&q=80" alt="Caballo">
                        </div>
                        <div class="offer-details">
                            <span class="offer-category">Aventura</span>
                            <h3>Paseo a Caballo</h3>
                            
                            <div class="offer-description">
                                <p class="short-desc">Exploración guiada por dunas y playas de Cascais.</p>
                                
                                <div class="full-info-box">
                                    <p class="full-desc">Siente la brisa del mar mientras cabalgas por la arena. Experiencia adaptada para principiantes o jinetes experimentados, con caballos lusitanos entrenados y guía profesional.</p>
                                    <ul class="offer-specs">
                                        <li><i class="fa-regular fa-clock"></i> <strong>Duración:</strong> 1h30 (Salidas a las 10h y 16h)</li>
                                        <li><i class="fa-solid fa-location-dot"></i> <strong>Punto de encuentro:</strong> Recepción del Centro Hípico</li>
                                        <li><i class="fa-solid fa-euro-sign"></i> <strong>Coste:</strong> 65€ por persona</li>
                                    </ul>
                                </div>
                            </div>

                            <div class="offer-footer">
                                <span class="price-tag">65€</span>
                                <span class="btn-text">Saber Más <i class="fa-solid fa-plus"></i></span>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <section class="location-section">
            <div class="header-container">
                <div class="location-content" style="text-align: center; margin-bottom: 30px;">
                    <span class="badge badge-gold">Dónde Estamos</span>
                    <h2 class="section-title">Ubicación Privilegiada</h2>
                    <p class="location-address">
                        <i class="fas fa-map-marker-alt"></i> 
                        Av. Rei Humberto II de Itália, Cascais, Portugal
                    </p>
                </div>
                
                <div class="map-container">
                    <iframe 
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d12457.14371900223!2d-9.429712!3d38.691763!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd1ec44238e55555%3A0x500ebb3233f0a50!2sCascais!5e0!3m2!1spt-PT!2spt!4v1700000000000!5m2!1spt-PT!2spt" 
                        width="100%" 
                        height="450" 
                        style="border:0; border-radius: 15px; box-shadow: var(--shadow-md);" 
                        allowfullscreen="" 
                        loading="lazy">
                    </iframe>
                </div>
            </div>
        </section>

    </main>

    <footer metal:fill-slot="main-footer"></footer>

</body>
</html>